export HOMEBREW_NO_ANALYTICS=1
export HOMEBREW_AUTO_UPDATE_SECS=604800
export HOMEBREW_NO_AUTO_UPDATE=1
export HOMEBREW_INSTALL_CLEANUP=1
export HOMEBREW_NO_ENV_HINTS=1
export FZF_DEFAULT_COMMAND='rg --hidden --files --ignore-file ~/.ignore'
export FZF_CTRL_T_COMMAND=$FZF_DEFAULT_COMMAND
export TIMEFMT=$'\nreal\t%*E\nuser\t%*U\nsys\t%*S'

export LANG="en_US.UTF-8"
export LC_ALL="en_US.UTF-8"
export LC_CTYPE="en_US.UTF-8"

# brew shellenv (cached — refresh: rm ~/.cache/zsh-evals/brew.zsh)
if [[ ! -s ~/.cache/zsh-evals/brew.zsh || /opt/homebrew/bin/brew -nt ~/.cache/zsh-evals/brew.zsh ]]; then
  [[ -d ~/.cache/zsh-evals ]] || mkdir -p ~/.cache/zsh-evals
  /opt/homebrew/bin/brew shellenv > ~/.cache/zsh-evals/brew.zsh
fi
source ~/.cache/zsh-evals/brew.zsh

export PATH="$HOME/.local/bin:$HOME/.bin:$HOME/.lmstudio/bin:$PATH"
