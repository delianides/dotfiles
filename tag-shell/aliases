# worktrunk: switch worktrees. `*n` variants pass --no-hooks, so they skip
# the tmux/direnv pre-start setup.
alias ws='wt switch'
alias wsn='wt switch --no-hooks'
alias wsc='wt switch --create'
alias wscn='wt switch --create --no-hooks'

# Interactive worktree picker via the `worktrees` television cable.
# Picks a worktree and `wt switch`es to it. Removal moved to plain `wt remove`
# (or use the `wsi-rm` helper directly) — tv cables select, they don't act.
wsi() {
  local picked branch
  picked=$(tv worktrees) || return
  branch=${picked%% *}
  [ -n "$branch" ] && wt switch "$branch"
}

# Interactive process killer via the `processes` television cable.
# Type to filter inside tv; pass -9 / -KILL to send SIGKILL instead of SIGTERM.
pskill() {
  local sig="TERM" arg
  for arg in "$@"; do
    case "$arg" in
      -9|-KILL|-kill) sig="KILL" ;;
      -*) sig="${arg#-}" ;;
    esac
  done
  local picked pids
  picked=$(tv processes) || return
  pids=$(printf '%s\n' "$picked" | awk '{print $1}')
  [ -z "$pids" ] && return
  echo "Sending SIG$sig to:"
  printf '%s\n' "$picked" | awk '{printf "  pid=%s  cwd=%s\n", $1, $2}'
  # shellcheck disable=SC2086
  kill -s "$sig" $pids
}

# Interactive symbol jump via the `symbols` television cable.
# rg emits file:line:col:text; open the selection in $VISUAL / $EDITOR at line.
tvs() {
  local sel file line editor
  sel=$(tv symbols) || return
  [ -z "$sel" ] && return
  file=${sel%%:*}
  line=$(printf '%s\n' "$sel" | cut -d: -f2)
  editor=${VISUAL:-${EDITOR:-nvim}}
  case "$editor" in
    *nvim*|*vim*) "$editor" "+$line" "$file" ;;
    *zed*)        "$editor" "$file:$line" ;;
    *code*)       "$editor" --goto "$file:$line" ;;
    *)            "$editor" "+$line" "$file" ;;
  esac
}

# Look up a Linear ticket via the Linear MCP server and print its git branch
# name. Uses claude haiku in -p mode.
lbn() {
  if [ -z "$1" ]; then
    echo "Usage: lbn <TICKET-ID>" >&2
    return 1
  fi
  CLAUDECODE= MAX_THINKING_TOKENS=0 claude -p \
    --no-session-persistence \
    --model=haiku \
    --disable-slash-commands \
    --setting-sources='' \
    --tools='' \
    --allowed-tools 'mcp__linear__get_issue' \
    --permission-mode bypassPermissions \
    --system-prompt='Look up the given Linear ticket via mcp__linear__get_issue and output only its gitBranchName field. No explanation, no quotes, no markdown.' \
    "$1"
}
