alias qq="cd . && source ~/.zshrc"
alias reload!='RELOAD=1 source ~/.zshrc'
alias diff="colordiff -u"
alias pn="pnpm"

alias k='kubectl --kubeconfig $HOME/.kubeconfig-integrations-developer'

alias tmux="tmux -2"
alias ssh='TERM=xterm-256color ssh'
alias vi='$VISUAL'
alias vim='$VISUAL'
alias rm="trash"
alias cat="bat"
alias mkdir="mkdir -p"

# eza
alias l="eza -abghHlS --git --group-directories-first"
alias ls="eza"
alias ll="eza -alh"
alias tree="eza --tree"

# Navigation
alias ..='cd ..'
alias ...='cd ../..'
alias ....='cd ../../..'
alias .....='cd ../../../..'

# Misc
alias dig="dig +noall +answer +multiline"
alias grep='grep --color=auto'
alias sed="sed -E"
alias crontab="VISUAL=vim crontab"

# Broadcast `cd <dir>` to every terminal surface in the current cmux workspace
# (cmux has no synchronize-panes). Defaults to $PWD.
alias cdall="cmux-cd-all"

# worktrunk: switch worktrees. `wsc` creates the worktree (running hooks) and
# attaches to the tmux session its pre-start hook spawns. `*n` variants pass
# --no-hooks, so they skip the tmux/direnv setup (and don't attach).
alias ws='wt switch'
alias wsc='wt switch --create -x "tmux attach -t {{ branch | sanitize }}"'
alias wsn='wt switch --no-hooks'
alias wscn='wt switch --create --no-hooks'

# Look up a Linear ticket via the Linear MCP server and print its git branch
# name. Uses claude haiku in -p mode.
lbn() {
  if [ -z "$1" ]; then
    echo "Usage: lbn <TICKET-ID>" >&2
    return 1
  fi
  CLAUDECODE= MAX_THINKING_TOKENS=0 claude -p \
    --no-session-persistence \
    --model=haiku \
    --disable-slash-commands \
    --setting-sources='' \
    --tools='' \
    --allowed-tools 'mcp__linear__get_issue' \
    --permission-mode bypassPermissions \
    --system-prompt='Look up the given Linear ticket via mcp__linear__get_issue and output only its gitBranchName field. No explanation, no quotes, no markdown.' \
    "$1"
}
