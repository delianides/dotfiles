{
  "env": {
    "CLAUDE_CODE_DISABLE_FEEDBACK_SURVEY": "1"
  },
  "permissions": {
    "allow": [
      "mcp__pencil",
      "Grep",
      "Read",
      "Glob",
      "WebSearch",
      "Edit(*.md)",
      "Bash(sed:*)",
      "Bash(cat:*)",
      "Bash(fd:*)",
      "Bash(which:*)",
      "Bash(ls:*)"
    ],
    "defaultMode": "auto"
  },
  "statusLine": {
    "type": "command",
    "command": "wt list statusline --format=claude-code",
    "padding": 0
  },
  "enabledPlugins": {
    "rust-analyzer-lsp@claude-plugins-official": true,
    "cmux-claude-code@local": true,
    "worktrunk@worktrunk": true,
    "superpowers@claude-plugins-official": true,
    "obsidian@obsidian-skills": true,
    "lua-lsp@claude-plugins-official": true,
    "pyright-lsp@claude-plugins-official": true,
    "ai@canary-plugins": true,
    "backend@canary-plugins": true,
    "core@canary-plugins": true,
    "dx@canary-plugins": true,
    "factory@canary-plugins": true,
    "mcp@canary-plugins": true,
    "orbkit@canary-plugins": true,
    "pms-gateway@canary-plugins": true,
    "testing@canary-plugins": true,
    "triage@canary-plugins": true,
    "investigate@canary-plugins": true
  },
  "extraKnownMarketplaces": {
    "worktrunk": {
      "source": {
        "source": "github",
        "repo": "max-sixty/worktrunk"
      }
    },
    "superpowers-marketplace": {
      "source": {
        "source": "github",
        "repo": "obra/superpowers-marketplace"
      }
    },
    "obsidian-skills": {
      "source": {
        "source": "github",
        "repo": "kepano/obsidian-skills"
      }
    }
  },
  "effortLevel": "high",
  "tui": "fullscreen",
  "skipDangerousModePermissionPrompt": true,
  "theme": "dark-daltonized",
  "editorMode": "vim",
  "agentPushNotifEnabled": true,
  "skipAutoPermissionPrompt": true,
  "voiceEnabled": true
}
