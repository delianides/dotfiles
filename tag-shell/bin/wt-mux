#!/usr/bin/env bash
# wt-mux: unified multiplexer dispatcher for worktrunk hooks.
#
# Detects cmux via `cmux ping`. If cmux is running, manages a cmux workspace
# named after the worktree branch (or supplied name). Otherwise falls back to
# zellij, with the session name truncated to fit the macOS Unix-socket-path cap
# (see zellij issue #4211).
#
# Subcommands:
#   open    --name NAME --cwd PATH [--layout NAME]
#           Ensure a workspace/session with the given name exists; select it.
#   close   --name NAME
#           Close/kill a workspace/session with the given name. Best-effort:
#           tries cmux first if running, then zellij with both the full and
#           truncated forms (covers users who switched backends mid-worktree).
#   list    Print workspace/session names, one per line, for fzf consumers.
#   backend Print "cmux" or "zellij".

set -uo pipefail

CMUX_LAYOUT_DIR="${HOME}/.config/cmux/layouts"
ZELLIJ_LAYOUT_DIR="${HOME}/.config/zellij/layouts"

_cmux_running() { cmux ping >/dev/null 2>&1; }
_backend()      { _cmux_running && echo cmux || echo zellij; }

# Resolve a layout file path for the given backend, falling back from
# explicit override -> repo-name -> default. Empty if no match.
#
# Repo name comes from the parent of `git rev-parse --git-common-dir` so
# that worktrees resolve to the main repo (e.g. canary, not drew-pms-8170-...).
_layout_for() {
  local kind="$1" cwd="$2" override="${3:-}"
  local ext dir repo common
  case "$kind" in
    cmux)   ext=json;  dir="$CMUX_LAYOUT_DIR"   ;;
    zellij) ext=kdl;   dir="$ZELLIJ_LAYOUT_DIR" ;;
    *) return ;;
  esac
  if [ -n "$override" ] && [ -f "$dir/$override.$ext" ]; then
    printf '%s\n' "$dir/$override.$ext"
    return
  fi
  common=$(git -C "$cwd" rev-parse --path-format=absolute --git-common-dir 2>/dev/null || true)
  [ -n "$common" ] && repo=$(basename "$(dirname "$common")")
  if [ -n "$repo" ] && [ -f "$dir/$repo.$ext" ]; then
    printf '%s\n' "$dir/$repo.$ext"
  elif [ -f "$dir/default.$ext" ]; then
    printf '%s\n' "$dir/default.$ext"
  fi
}

# Truncate to fit zellij's macOS socket-path limit (24 chars on default $TMPDIR).
# Branches <= 24 chars pass through. Longer ones become 20-char prefix + 3-char
# hash suffix for collision resistance and determinism.
_zellij_short_name() {
  local name="$1"
  if [ "${#name}" -le 24 ]; then
    printf '%s\n' "$name"
  else
    local hash
    hash=$(printf '%s' "$name" | shasum | cut -c1-3)
    printf '%s-%s\n' "${name:0:20}" "$hash"
  fi
}

# Look up a cmux workspace ref by its title. Empty if not found.
_cmux_find() {
  local name="$1"
  cmux --json list-workspaces 2>/dev/null \
    | jq -r --arg n "$name" '
        ([ .[]? | select((.name? // .title? // "") == $n) ] | first | .ref // .id // empty)
      ' 2>/dev/null || true
}

cmd_open() {
  local name="" cwd="$PWD" layout=""
  while [ $# -gt 0 ]; do
    case "$1" in
      --name)   name="$2"; shift 2 ;;
      --cwd)    cwd="$2";  shift 2 ;;
      --layout) layout="$2"; shift 2 ;;
      *) shift ;;
    esac
  done
  if [ -z "$name" ]; then
    echo "wt-mux open: --name required" >&2
    exit 1
  fi
  [ -d "$cwd" ] || cwd="$PWD"

  if _cmux_running; then
    local ref
    ref=$(_cmux_find "$name")
    if [ -z "$ref" ]; then
      local layout_path layout_arg=()
      layout_path=$(_layout_for cmux "$cwd" "$layout")
      if [ -n "$layout_path" ] && command -v jq >/dev/null 2>&1; then
        layout_arg=(--layout "$(jq -c . "$layout_path")")
      fi
      # --focus true: cmux new-workspace defaults to false, so without this
      # the workspace is created but not selected.
      ref=$(cmux new-workspace --name "$name" --cwd "$cwd" --focus true "${layout_arg[@]}" 2>/dev/null \
            | awk 'NR==1 {print $1}')
    elif [ -n "$ref" ]; then
      cmux select-workspace --workspace "$ref" >/dev/null 2>&1 || true
    fi
  else
    local short layout_path layout_name="default"
    short=$(_zellij_short_name "$name")
    layout_path=$(_layout_for zellij "$cwd" "$layout")
    [ -n "$layout_path" ] && layout_name=$(basename "$layout_path" .kdl)
    if zellij list-sessions -s 2>/dev/null | grep -Fxq "$short"; then
      exec zellij attach "$short"
    else
      exec zellij -s "$short" -n "$layout_name"
    fi
  fi
}

cmd_close() {
  local name=""
  while [ $# -gt 0 ]; do
    case "$1" in
      --name) name="$2"; shift 2 ;;
      *) shift ;;
    esac
  done
  [ -z "$name" ] && return 0

  if _cmux_running; then
    # Focus the pinned workspace at index 0 (MAIN by convention) before
    # tearing down the target so cmux doesn't auto-select a random workspace.
    cmux select-workspace --workspace 0 >/dev/null 2>&1 || true

    local ref
    ref=$(_cmux_find "$name")
    if [ -n "$ref" ]; then
      cmux close-workspace --workspace "$ref" >/dev/null 2>&1 || true
    fi
  fi

  local short
  short=$(_zellij_short_name "$name")
  for s in "$name" "$short"; do
    zellij kill-session   "$s"          >/dev/null 2>&1 || true
    zellij delete-session "$s" --force  >/dev/null 2>&1 || true
  done
}

cmd_list() {
  if _cmux_running; then
    cmux --json list-workspaces 2>/dev/null \
      | jq -r '.[]? | (.name? // .title? // "") | select(length > 0)' 2>/dev/null
  else
    zellij list-sessions -s 2>/dev/null
  fi
}

cmd_backend() { _backend; }

main() {
  local sub="${1:-}"
  shift || true
  case "$sub" in
    open)    cmd_open    "$@" ;;
    close)   cmd_close   "$@" ;;
    list)    cmd_list    "$@" ;;
    backend) cmd_backend "$@" ;;
    *) echo "Usage: wt-mux <open|close|list|backend> [args]" >&2; exit 1 ;;
  esac
}

main "$@"
