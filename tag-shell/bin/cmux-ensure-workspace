#!/usr/bin/env bash
# cmux-ensure-workspace — select the cmux workspace matching a title, or create
# it (claude + shell split) if none exists. Claude runs inside a persistent zmx
# session named "<name>.claude" so it survives the workspace being closed.
# Shared by worktrunk's pre-start hook (create path) and post-switch hook
# (switch path) so both always land you in a workspace. No-op when cmux is
# absent. Requires zmx for the claude pane (already a hard dependency, see trg).
#
# Group-aware: when invoked from a workspace that belongs to a sidebar group
# (the caller is $CMUX_WORKSPACE_ID, set inside every cmux terminal), the
# existence check is scoped to that group's members and a freshly created
# workspace is added to the same group instead of landing at the top level.
#
# Usage: cmux-ensure-workspace <name> <cwd>

set -euo pipefail

name="${1:?usage: cmux-ensure-workspace <name> <cwd>}"
cwd="${2:?usage: cmux-ensure-workspace <name> <cwd>}"

# Bail quietly if the cmux CLI isn't on PATH.
command -v cmux >/dev/null 2>&1 || exit 0

# Silence the "<cmd> is now an alias for ..." legacy-command notices (stderr).
export CMUX_QUIET=1

# If the caller's workspace belongs to a sidebar group, capture that group's ref
# and its member refs. $CMUX_WORKSPACE_ID is a UUID, so match it against
# member_workspace_ids (exposed by `--id-format both`). Both stay empty when the
# caller isn't running inside cmux or its workspace isn't grouped.
group_ref=""
members_json="[]"
if [ -n "${CMUX_WORKSPACE_ID:-}" ]; then
  group=$( { cmux --id-format both workspace-group list --json 2>/dev/null || true; } |
    jq -c --arg w "$CMUX_WORKSPACE_ID" \
      'first(.groups[]? | select((.member_workspace_ids // []) | index($w))) // empty' 2>/dev/null) || group=""
  if [ -n "$group" ]; then
    group_ref=$(jq -r '.ref' <<<"$group")
    members_json=$(jq -c '.member_workspace_refs // []' <<<"$group")
  fi
fi

# Find an existing workspace whose title matches. When the caller is grouped,
# scope the match to that group's members so a same-named workspace elsewhere
# doesn't shadow it (and so we create one inside the group when it's missing
# there). `first(...) // empty` avoids piping through `head`, which would
# SIGPIPE under `set -o pipefail` and falsely blank out a real match.
if [ -n "$group_ref" ]; then
  ws=$(cmux --json list-workspaces 2>/dev/null |
    jq -r --arg t "$name" --argjson m "$members_json" \
      'first(.workspaces[]? | select(.title == $t) | .ref | select($m | index(.))) // empty') || ws=""
else
  ws=$(cmux --json list-workspaces 2>/dev/null |
    jq -r --arg t "$name" 'first(.workspaces[]? | select(.title == $t) | .ref) // empty') || ws=""
fi

if [ -n "$ws" ]; then
  cmux select-workspace --workspace "$ws"
else
  # Run Claude inside a persistent zmx session so it survives the cmux workspace
  # being closed and restored. zmx appends ZMX_SESSION_PREFIX directly onto the
  # session name with no separator, so the trailing "." here yields a session
  # named "<prefix>.claude". The prefix is the workspace name with every
  # non-alphanumeric character folded to a hyphen, keeping it zmx-safe.
  zmx_prefix="${name//[^a-zA-Z0-9-]/-}"
  claude_cmd="ZMX_SESSION_PREFIX='${zmx_prefix}.' zmx attach claude claude"

  # Build the layout with jq so the embedded command is JSON-escaped correctly.
  layout=$(jq -nc --arg cmd "$claude_cmd" '{
    direction: "vertical",
    split: 0.7,
    children: [
      { pane: { surfaces: [ { type: "terminal", name: "claude", command: $cmd } ] } },
      { pane: { surfaces: [ { type: "terminal", name: "shell" } ] } }
    ]
  }')

  # `new-workspace` prints "OK <ref>"; capture the ref so we can group it below.
  new_ws=$(cmux new-workspace \
    --name "$name" \
    --cwd "$cwd" \
    --focus true \
    --layout "$layout" | awk '/^OK /{print $2; exit}') || new_ws=""

  # Inherit the caller's group: nest the new workspace under the same sidebar
  # group instead of leaving it at the top level.
  if [ -n "$group_ref" ] && [ -n "$new_ws" ]; then
    cmux workspace-group add --group "$group_ref" --workspace "$new_ws" || true
  fi
fi
