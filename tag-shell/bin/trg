#!/usr/bin/env bash
# trg TICKET
# Open a persistent zmx session named after a Linear ticket and launch
# Claude Code seeded with the /investigate-ticket slash command for it.
# Re-running with the same ticket re-attaches to the existing session.
#
# When launched inside a cmux workspace, rename that workspace after the
# ticket and forward the CMUX_* environment into the zmx session so the
# Claude process inside can drive cmux (status, panes, rename) for the right
# workspace. zmx already forwards the caller env on session creation, so the
# explicit pass-through is belt-and-suspenders that also documents the
# dependency.
set -euo pipefail

ticket="${1:?usage: trg TICKET}"
ticket="$(printf '%s' "$ticket" | tr '[:lower:]' '[:upper:]')"

# The session inherits its cwd from here; default to the canary repo.
cd "${TRG_CWD:-$HOME/Work/canary}"

if [ -n "${CMUX_WORKSPACE_ID:-}" ]; then
  # Rename the current cmux workspace after the ticket (non-fatal on failure).
  cmux rename-workspace --workspace "$CMUX_WORKSPACE_ID" -- "$ticket" || true

  # Forward every CMUX_* var into the new zmx session.
  cmux_env=()
  while IFS= read -r var; do
    cmux_env+=("$var")
  done < <(env | grep '^CMUX')

  exec env "${cmux_env[@]}" zmx attach "$ticket" claude "/investigate-ticket $ticket"
fi

exec zmx attach "$ticket" claude "/investigate-ticket $ticket"
