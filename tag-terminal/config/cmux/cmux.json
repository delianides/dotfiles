{
  "$schema": "https://raw.githubusercontent.com/manaflow-ai/cmux/main/web/data/cmux.schema.json",
  "schemaVersion": 1,

  "automation": {
    "claudeBinaryPath": "$HOME/.local/bin/claude"
  },

  "shortcuts": {
    "bindings": {
      "focusLeft": "ctrl+h",
      "focusDown": "ctrl+j",
      "focusUp": "ctrl+k",
      "focusRight": "ctrl+l",
      "nextSurface": ["ctrl+a", "n"],
      "prevSurface": ["ctrl+a", "p"],
      "goToWorkspace": "ctrl+o"
    }
  },
  "actions": {
    "claude": {
      "type": "command",
      "title": "Claude Code",
      "command": "claude --dangerously-skip-permissions",
      "target": "newTabInCurrentPane",
      "shortcut": ["ctrl+a", "shift+a"],
      "icon": { "type": "image", "path": "~/.config/cmux/icons/claude.svg" }
    },
    "codex": {
      "type": "command",
      "title": "Codex",
      "command": "codex --dangerously-bypass-approvals-and-sandbox",
      "target": "newTabInCurrentPane",
      "icon": { "type": "image", "path": "~/.config/cmux/icons/codex.svg" }
    },
    "opencode": {
      "type": "command",
      "title": "OpenCode",
      "command": "opencode",
      "target": "newTabInCurrentPane",
      "icon": { "type": "image", "path": "~/.config/cmux/icons/opencode.svg" }
    },
    "pi": {
      "type": "command",
      "title": "Pi",
      "command": "pi",
      "target": "newTabInCurrentPane",
      "icon": { "type": "image", "path": "~/.config/cmux/icons/pi.svg" }
    },
    "default-layout": {
      "type": "workspaceCommand",
      "commandName": "New Workspace",
      "title": "New Workspace",
      "subtitle": "claude top / terminal bottom",
      "keywords": ["layout", "split", "stack", "default"],
      "palette": true
    },
    "canary-thread": {
      "type": "workspaceCommand",
      "commandName": "New Canary Thread",
      "title": "New Canary Thread",
      "subtitle": "Canary Specific Thread",
      "keywords": ["canary", "worktree", "wt", "pms-gateway", "agents"],
      "icon": { "type": "symbol", "name": "folder.badge.plus" },
      "palette": true
    }
  },

  "commands": [
    {
      "name": "New Workspace",
      "description": "Top pane claude, bottom pane terminal",
      "keywords": ["layout", "split", "stack"],
      "workspace": {
        "name": "Workspace",
        "cwd": "~/Work",
        "layout": {
          "direction": "vertical",
          "split": 0.667,
          "children": [
            {
              "pane": {
                "surfaces": [
                  {
                    "type": "terminal",
                    "name": "claude",
                    "command": "claude",
                    "focus": true
                  }
                ]
              }
            },
            {
              "pane": {
                "surfaces": [{ "type": "terminal", "name": "bottom" }]
              }
            }
          ]
        }
      }
    },
    {
      "name": "New Canary Thread",
      "description": "Top pane claude, bottom pane terminal",
      "keywords": ["layout", "split", "stack"],
      "workspace": {
        "name": "Workspace",
        "cwd": "~/Work/canary",
        "layout": {
          "direction": "vertical",
          "split": 0.667,
          "children": [
            {
              "pane": {
                "surfaces": [
                  {
                    "type": "terminal",
                    "name": "claude",
                    "command": "claude",
                    "focus": true
                  }
                ]
              }
            },
            {
              "pane": {
                "surfaces": [{ "type": "terminal", "name": "bottom" }]
              }
            }
          ]
        }
      }
    }
  ],
  "ui": {
    "surfaceTabBar": {
      "buttons": [
        { "id": "newTerminal", "builtin": "cmux.newTerminal" },
        { "id": "splitRight", "builtin": "cmux.splitRight" },
        { "id": "splitDown", "builtin": "cmux.splitDown" },
        { "id": "claude", "action": "claude" },
        { "id": "codex", "action": "codex" },
        { "id": "opencode", "action": "opencode" },
        { "id": "pi", "action": "pi" }
      ]
    },
    "newWorkspace": {
      "action": "default-layout",
      "contextMenu": [
        {
          "action": "default-layout",
          "title": "New Workspace"
        },
        { "type": "separator" },
        {
          "action": "canary-thread",
          "title": "New Canary Thread"
        }
      ]
    }
  }
}
